generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  // Game stats
  xp           Int      @default(0)
  level        Int      @default(1)
  streakDays   Int      @default(0)
  lastActiveAt DateTime?
  totalXp      Int      @default(0)

  // Learning config
  targetLanguage String   @default("fr")
  goalType       String   @default("social") // travel | social | business
  deadlineDate   DateTime?
  dailyMinutes   Int      @default(15)
  onboardedAt    DateTime?  // null = needs onboarding wizard

  // Admin controls
  isBlocked          Boolean @default(false)
  monthlyTokenBudget Int?    // null = unlimited; unit = total tokens (input + output)

  // Relations
  grammarProfiles GrammarProfile[]
  userLanguages   UserLanguage[]
  vocabulary      UserVocabulary[]
  sessions        ConversationSession[]
  achievements    UserAchievement[]
  streakHistory   StreakEntry[]
}

// Per-user, per-language language enrollment and active state.
model UserLanguage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  languageCode String
  startedAt    DateTime @default(now())
  lastActiveAt DateTime?
  isActive     Boolean  @default(false)

  @@unique([userId, languageCode])
  @@index([userId, isActive])
}

// Per-user, per-language grammar progress.
// Compound unique replaces the old single-field userId unique.
model GrammarProfile {
  id           String @id @default(cuid())
  userId       String
  languageCode String @default("fr")
  user         User   @relation(fields: [userId], references: [id])

  deconstructionDone      Boolean  @default(false)
  deconstructionProgress  Int      @default(0)
  deconstructionCardState Json     @default("{}")
  cheatSheetMd            String?
  patternScores           Json     @default("{}")
  completedAt             DateTime?

  @@unique([userId, languageCode])
}

model LanguageWord {
  id              String @id @default(cuid())
  languageCode    String
  frequencyRank   Int
  word            String
  translation     String
  pronunciation   String?
  exampleSentence String?
  mnemonicHint    String?
  audioUrl        String?
  category        String? // verb | noun | adjective | phrase | slang

  userVocabulary UserVocabulary[]

  @@unique([languageCode, frequencyRank])
  @@index([languageCode, frequencyRank])
}

model UserVocabulary {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id])
  wordId String
  word   LanguageWord @relation(fields: [wordId], references: [id])

  // FSRS fields
  stability  Float    @default(0)
  difficulty Float    @default(0)
  dueDate    DateTime @default(now())
  lastReview DateTime?
  reps       Int      @default(0)
  lapses     Int      @default(0)
  state      Int      @default(0) // 0=New 1=Learning 2=Review 3=Relearning

  // Learn-mode tracking (pre-FSRS exposure)
  seenCount         Int  @default(0)
  initialConfidence Int?

  // Gamification
  timesCorrect Int @default(0)
  timesFailed  Int @default(0)
  xpEarned     Int @default(0)

  @@unique([userId, wordId])
}

model ConversationSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  languageCode String   @default("fr")
  createdAt    DateTime @default(now())
  duration     Int?     // seconds

  mode         String  @default("guided") // guided | freeform
  scenarioType String?
  transcript   String?

  wordsEncountered String[]
  errorsLogged     Json     @default("[]")
  xpEarned         Int      @default(0)
  newWordsCount    Int      @default(0)
  accuracyPct      Int?

  // Session objective — set at session start by the planner
  sessionObjective Json?    // SessionObjective shape from session-planner.ts
  patternUses      Int      @default(0) // how many times the target pattern was used
  objectiveReached Boolean?            // did the learner hit requiredUses?

  // Usage tracking — written incrementally by the agent via /api/internal/usage
  inputTokens  Int   @default(0)
  outputTokens Int   @default(0)
  ttsChars     Int   @default(0)   // Deepgram TTS billed per char
  sttSeconds   Float @default(0)   // Deepgram STT billed per second

  @@index([userId, languageCode, createdAt])
  @@index([createdAt])
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  xpReward    Int    @default(0)
  category    String // vocab | streak | conversation | grammar

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model StreakEntry {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  date     DateTime
  xpEarned Int      @default(0)

  @@unique([userId, date])
}
