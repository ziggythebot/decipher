generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  // Game stats
  xp           Int      @default(0)
  level        Int      @default(1)
  streakDays   Int      @default(0)
  lastActiveAt DateTime?
  totalXp      Int      @default(0)

  // Learning config
  targetLanguage String   @default("fr")
  goalType       String   @default("social") // travel | social | business
  deadlineDate   DateTime?
  dailyMinutes   Int      @default(15)

  // Relations
  grammarProfile GrammarProfile?
  vocabulary     UserVocabulary[]
  sessions       ConversationSession[]
  achievements   UserAchievement[]
  streakHistory  StreakEntry[]
}

model GrammarProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  deconstructionDone Boolean  @default(false)
  cheatSheetMd       String?
  patternScores      Json     @default("{}")
  completedAt        DateTime?
}

model LanguageWord {
  id            String @id @default(cuid())
  languageCode  String
  frequencyRank Int
  word          String
  translation   String
  pronunciation String?
  exampleSentence String?
  mnemonicHint  String?
  audioUrl      String?
  category      String? // verb | noun | adjective | phrase

  userVocabulary UserVocabulary[]

  @@unique([languageCode, frequencyRank])
  @@index([languageCode, frequencyRank])
}

model UserVocabulary {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id])
  wordId String
  word   LanguageWord @relation(fields: [wordId], references: [id])

  // FSRS fields
  stability  Float    @default(0)
  difficulty Float    @default(0)
  dueDate    DateTime @default(now())
  lastReview DateTime?
  reps       Int      @default(0)
  lapses     Int      @default(0)
  state      Int      @default(0) // 0=New 1=Learning 2=Review 3=Relearning

  // Gamification
  timesCorrect Int @default(0)
  timesFailed  Int @default(0)
  xpEarned     Int @default(0)

  @@unique([userId, wordId])
}

model ConversationSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  duration  Int?     // seconds

  mode         String  @default("guided") // guided | freeform
  scenarioType String?
  transcript   String?

  wordsEncountered String[]
  errorsLogged     Json     @default("[]")
  xpEarned         Int      @default(0)
  newWordsCount    Int      @default(0)
  accuracyPct      Int?
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  xpReward    Int    @default(0)
  category    String // vocab | streak | conversation | grammar

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model StreakEntry {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  date     DateTime
  xpEarned Int      @default(0)

  @@unique([userId, date])
}
